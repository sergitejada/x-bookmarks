{
  "manifest_version": 3,
  "name": "X Bookmarks Exporter",
  "version": "0.1.0",
  "description": "Captura tus bookmarks de X/Twitter mientras haces scroll en x.com/i/bookmarks y los envía a tu app local.",
  "permissions": ["storage"],
  "host_permissions": ["http://localhost:3005/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "X Bookmarks Exporter"
  }
}
